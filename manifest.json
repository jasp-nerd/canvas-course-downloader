{
  "manifest_version": 3,
  "name": "Canvas Course Downloader",
  "description": "One-click bulk download of all files, assignments, modules, pages, syllabus, discussions, and announcements from Canvas LMS courses.",
  "version": "1.9.0",
  "browser_specific_settings": {
    "gecko": {
      "id": "canvas-course-downloader@jasp-nerd",
      "strict_min_version": "121.0"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "downloads",
    "notifications",
    "storage"
  ],
  "host_permissions": [
    "*://*/",
    "*://*.instructure.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*/*"
      ],
      "js": ["jszip.min.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/icon-128.png"],
      "matches": ["https://*/*"]
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Canvas Course Downloader"
  },
  "commands": {
    "download-current": {
      "suggested_key": {
        "default": "Ctrl+Shift+D",
        "mac": "Command+Shift+D"
      },
      "description": "Download current course or open course selector"
    }
  }
}
