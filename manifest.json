{
  "manifest_version": 3,
  "name": "Canvas Course Downloader & Exporter",
  "description": "Download, export, and back up Canvas LMS course files, pages, assignments, grades, and more into organized folders.",
  "version": "2.1.0",
  "browser_specific_settings": {
    "gecko": {
      "id": "canvas-course-downloader@jasp-nerd",
      "strict_min_version": "121.0"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "activeTab",
    "downloads",
    "notifications",
    "storage"
  ],
  "host_permissions": [
    "*://*.instructure.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*/*"
      ],
      "js": [
        "jszip.min.js",
        "helpers.js",
        "detector.js",
        "canvas-api.js",
        "ui.js",
        "downloader.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/icon-128.png"],
      "matches": ["https://*/*"]
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Canvas Course Downloader"
  },
  "commands": {
    "download-current": {
      "suggested_key": {
        "default": "Ctrl+Shift+D",
        "mac": "Command+Shift+D"
      },
      "description": "Download current course or open course selector"
    }
  }
}
